@{
    ViewData["Title"] = "Trang Chủ - Hotel Luxury";
}

<!-- 1. Hình bìa khách sạn (Hero Section) -->
<div class="hero-section" style="background: url('/images/hotel-cover.jpg') no-repeat center center; background-size: cover; height: 500px; position: relative;">
    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; color: white; text-shadow: 2px 2px 10px rgba(0,0,0,0.7);">
        <h1 class="display-3 fw-bold">HOTEL LUXURY</h1>
        <p class="lead">Trải nghiệm dịch vụ đẳng cấp và sang trọng bậc nhất</p>
        <a href="@Url.Action("Index", "Booking")" class="btn btn-primary btn-lg mt-3 shadow">ĐẶT PHÒNG NGAY</a>
    </div>
</div>

<div class="container mt-5">
    <div class="row">
        <!-- 2. Thông tin liên hệ & Địa chỉ -->
        <div class="col-md-6">
            <h2 class="text-primary">Thông Tin Liên Hệ</h2>
            <hr>
            <p><strong>📍 Địa chỉ:</strong> 123 Đường Bờ Biển, Phường 1, TP. Vũng Tàu</p>
            <p><strong>📞 Hotline:</strong> 0123.456.789</p>
            <p><strong>⭐ Đánh giá:</strong> 4.9/5 (Từ hơn 1000 khách hàng)</p>
            
            <!-- 3. Đánh giá khách hàng -->
            <div class="mt-4 p-3 bg-light border-start border-primary border-4">
                <h5>Đánh giá gần đây:</h5>
                <p><em>"Phòng ốc rất sạch sẽ, view biển tuyệt đẹp. Tôi và bạn tôi đã có một kỳ nghỉ rất tuyệt vời tại đây!"</em></p>
                <small class="text-muted">- Khách hàng thân thiết</small>
            </div>
        </div>

        <!-- 4. Google Maps -->
        <div class="col-md-6">
            <h2 class="text-primary">Vị Trí Bản Đồ</h2>
            <hr>
            <div class="ratio ratio-16x9">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3924.627233215509!2d107.0792!3d10.3460!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTDCsDIwJzQ1LjYiTiAxMDfCsDA0JzQ1LjEiRQ!5e0!3m2!1svi!2svn!4v1620000000000!5m2!1svi!2svn" 
                        style="border:0;" allowfullscreen="" loading="lazy"></iframe>
            </div>
        </div>
    </div>
</div>